{
  "name": "label-maker",
  "version": "1.0.0",
  "description": "SKU 標籤打印工具",
  "main": "main.js",
  "scripts": {
    "start": "node start.js",
    "build": "electron-builder --win"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "build": {
    "appId": "com.labelmaker.app",
    "productName": "Label Maker",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "files": [
      "main.js",
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ]
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "tesseract.js": "^7.0.0",
    "xlsx": "^0.18.5"
  }
}
